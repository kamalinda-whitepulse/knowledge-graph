# --- Ports exposed on your HOST machine ---
BACKEND_PORT=3000
FRONTEND_PORT=5173        # use 5173 if you like, when running the dev compose file

# --- Backend ---
# host.docker.internal lets the container reach MongoDB running on your host machine.
MONGO_URI=mongodb://host.docker.internal:27017/knowledge-graph
JWT_SECRET=tasha
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:5173

# --- Frontend ---
# Baked into the frontend bundle at BUILD time (production) via a build arg.
VITE_API_URL=http://localhost:3000